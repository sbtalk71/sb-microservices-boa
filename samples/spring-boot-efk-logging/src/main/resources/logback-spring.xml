<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <springProperty
            scope="context"
            name="APP_NAME"
            source="spring.application.name"/>

    <appender name="JSON"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">

            <providers>

                <timestamp/>

               <pattern>
                    <pattern>
                        {
                        "application":"${APP_NAME}",
                        "level":"%level",
                        "thread":"%thread",
                        "logger":"%logger",
                        "traceId":"%X{traceId:-}",
                        "spanId":"%X{spanId:-}",
                        "message":"%message"
                        }
                    </pattern>
</pattern>
            </providers>

        </encoder>

    </appender>

    <root level="INFO">
        <appender-ref ref="JSON"/>
    </root>

</configuration>